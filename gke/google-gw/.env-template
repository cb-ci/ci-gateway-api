#! /bin/bash
# --- Configuration ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PROJECT_ID=<YOUR_PROJECT_ID>
export NAMESPACE=${NAMESPACE:-cloudbees-gatewayapi}
export CONTROLLER_SERVICE_NAME=${CONTROLLER_SERVICE_NAME:-ha}
export CONTROLLER_NAME=${CONTROLLER_NAME:-ha}
export ZONE_NAME=${ZONE_NAME:-flow-training.beescloud.com}
export DOMAIN=${DOMAIN:-<YOUR_USER_OR_PREFIX>.$ZONE_NAME}
export CJOC_HOST_NAME=${CJOC_HOST_NAME:-gateway-google.$DOMAIN}


export REGION=${REGION:-us-east1}
export ZONE=${ZONE:-us-east1-d}
export CLUSTER_NAME=${CLUSTER_NAME:-cb-ci}
export CLOUDBEES_STORAGE_CLASS=${CLOUDBEES_STORAGE_CLASS:-ssd-cloudbees-ci-cjoc1}

# Gateway vars
export GATEWAY_NAME=${GATEWAY_NAME:-cloudbees-gateway}


# TLS / certificate settings
export CERT_DIR="${SCRIPT_DIR}/../scripts/ssl"
export CERT_NAME=<YOUR_CERT_NAME_PREFIX>-cert-selfsigned

# ---------------------------------------------------------------------------
# Tooling configuration
# ---------------------------------------------------------------------------
# Anchor kubeconfig to the script directory rather than CWD
export KUBECONFIG="${SCRIPT_DIR}/gke/kubeconfig"
export CLOUDSDK_PYTHON=python3.12



# GCP resource identifiers
# see https://cloud.google.com/apis/design/resource_names
export PROJECT_RESOURCE="//cloudresourcemanager.googleapis.com/projects/${PROJECT_ID}"

# GKE kubectl auth plugin
# see https://cloud.google.com/blog/products/containers-kubernetes/kubectl-auth-changes-in-gke
export USE_GKE_GCLOUD_AUTH_PLUGIN=True


# --- Colors for Logging ---
export RED='\033[0;31m'
export GREEN='\033[0;32m'
export BLUE='\033[0;34m'
export NC='\033[0m'


log()     { echo -e "${BLUE}[$(date +'%Y-%m-%dT%H:%M:%S')]${NC} $1"; }
success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
warn()    { echo -e "${RED}[WARNING]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1" >&2; exit 1; }

# --- Prerequisite Checks ---
log "Checking prerequisites..."
